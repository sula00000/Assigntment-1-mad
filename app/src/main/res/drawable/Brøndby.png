</div><div class="mw-content-ltr mw-parser-output" lang="en" dir="ltr"><div class="shortdescription nomobile noexcerpt noprint searchaux" style="display:none">Danish association football club</div>
<style data-mw-deduplicate="TemplateStyles:r1320445320">.mw-parser-output .hatnote{font-style:italic}.mw-parser-output div.hatnote{padding-left:1.6em;margin-bottom:0.5em}.mw-parser-output .hatnote i{font-style:normal}.mw-parser-output .hatnote+link+.hatnote{margin-top:-0.5em}@media print{body.ns-0 .mw-parser-output .hatnote{display:none!important}}</style><div role="note" class="hatnote navigation-not-searchable">This article is about the men's football team. For the women's football team, see <a href="/wiki/Br%C3%B8ndby_IF_(women)" title="Brøndby IF (women)">Brøndby IF (women)</a>.</div>
<p class="mw-empty-elt">
</p>
<div class="shortdescription nomobile noexcerpt noprint searchaux" style="display:none">Football club</div><style data-mw-deduplicate="TemplateStyles:r1316064257">.mw-parser-output .infobox-subbox{padding:0;border:none;margin:-3px;width:auto;min-width:100%;font-size:100%;clear:none;float:none;background-color:transparent;color:inherit}.mw-parser-output .infobox-3cols-child{margin:-3px}.mw-parser-output .infobox .navbar{font-size:100%}@media screen{html.skin-theme-clientpref-night .mw-parser-output .infobox-full-data:not(.notheme)>div:not(.notheme)[style]{background:#1f1f23!important;color:#f8f9fa}}@media screen and (prefers-color-scheme:dark){html.skin-theme-clientpref-os .mw-parser-output .infobox-full-data:not(.notheme)>div:not(.notheme)[style]{background:#1f1f23!important;color:#f8f9fa}}@media(min-width:640px){body.skin--responsive .mw-parser-output .infobox-table{display:table!important}body.skin--responsive .mw-parser-output .infobox-table>caption{display:table-caption!important}body.skin--responsive .mw-parser-output .infobox-table>tbody{display:table-row-group}body.skin--responsive .mw-parser-output .infobox-table th,body.skin--responsive .mw-parser-output .infobox-table td{padding-left:inherit;padding-right:inherit}}</style><style data-mw-deduplicate="TemplateStyles:r1151960987">body.skin-minerva .mw-parser-output .infobox table{display:table}body.skin-minerva .mw-parser-output .infobox caption{display:table-caption}</style><table class="infobox vcard"><caption class="infobox-title fn org">Brøndby IF</caption><tbody><tr><td colspan="2" class="infobox-image"><span typeof="mw:File"><a href="/wiki/File:Brondby_IF_logo.svg" class="mw-file-description"><img src="//upload.wikimedia.org/wikipedia/en/thumb/b/b5/Brondby_IF_logo.svg/250px-Brondby_IF_logo.svg.png" decoding="async" width="165" height="200" class="mw-file-element" srcset="//upload.wikimedia.org/wikipedia/en/thumb/b/b5/Brondby_IF_logo.svg/330px-Brondby_IF_logo.svg.png 2x" data-file-width="287" data-file-height="348" /></a></span></td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">Full name</th><td class="infobox-data">Brøndbyernes Idrætsforening</td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">Nicknames</th><td class="infobox-data nickname"><i>Drengene Fra Vestegnen</i><br />(The boys from <a href="/wiki/Vestegnen" title="Vestegnen">Vestegnen</a>)</td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">Founded</th><td class="infobox-data">3&#160;December 1964<span class="noprint">&#59;&#32;61 years ago</span><span style="display:none">&#160;(<span class="bday dtstart published updated">1964-12-03</span>)</span></td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">Stadium</th><td class="infobox-data label"><a href="/wiki/Br%C3%B8ndby_Stadium" title="Brøndby Stadium">Brøndby Stadium</a></td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">Capacity</th><td class="infobox-data">28,000</td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">Owner(s)</th><td class="infobox-data"><a href="/wiki/Global_Football_Holdings" class="mw-redirect" title="Global Football Holdings">Global Football Holdings</a> (50.1%)<br /><a href="/w/index.php?title=Jan_Bech_Andersen&amp;action=edit&amp;redlink=1" class="new" title="Jan Bech Andersen (page does not exist)">Jan Bech Andersen</a> (10%) <br /> Minority stockholders [&lt;5%] (39.9%)</td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">Chairman</th><td class="infobox-data agent"><a href="/w/index.php?title=Jan_Bech_Andersen&amp;action=edit&amp;redlink=1" class="new" title="Jan Bech Andersen (page does not exist)">Jan Bech Andersen</a></td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">Head coach</th><td class="infobox-data agent"><a href="/wiki/Steve_Cooper_(football_manager)" title="Steve Cooper (football manager)">Steve Cooper</a></td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">League</th><td class="infobox-data"><a href="/wiki/Danish_Superliga" title="Danish Superliga">Superliga</a></td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left"><a href="/wiki/2024%E2%80%9325_Danish_Superliga" title="2024–25 Danish Superliga">2024–25</a></th><td class="infobox-data"><a href="/wiki/Danish_Superliga" title="Danish Superliga">Superliga</a>, 3rd of 12</td></tr><tr><th scope="row" class="infobox-label" style="white-space: nowrap; text-align:left">Website</th><td class="infobox-data"><span class="official-website"><span class="url"><a rel="nofollow" class="external text" href="https://brondby.com/">brondby<wbr />.com</a></span></span> <span class="mw-valign-text-top" typeof="mw:File/Frameless"><a href="https://www.wikidata.org/wiki/Q211906#P856" title="Edit this at Wikidata"><img alt="Edit this at Wikidata" src="//upload.wikimedia.org/wikipedia/en/thumb/8/8a/OOjs_UI_icon_edit-ltr-progressive.svg/20px-OOjs_UI_icon_edit-ltr-progressive.svg.png" decoding="async" width="10" height="10" class="mw-file-element" data-file-width="20" data-file-height="20" /></a></span></td></tr><tr><td colspan="2" class="infobox-full-data"></td></tr><tr><td style="padding: 0; background: #fff; color:#000; text-align: center; border: 1px solid #D3D3D3;" colspan="2">
